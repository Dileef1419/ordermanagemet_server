{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Urls": "http://localhost:5000",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "RateLimiterPolicy": "standard",
        "Match": {
          "Path": "/api/v1/auth/{**catch-all}"
        }
      },
      "orders-route": {
        "ClusterId": "orders-cluster",
        "RateLimiterPolicy": "standard",
        "Match": {
          "Path": "/api/v1/orders/{**catch-all}"
        }
      },
      "payments-route": {
        "ClusterId": "payments-cluster",
        "RateLimiterPolicy": "standard",
        "Match": {
          "Path": "/api/v1/payments/{**catch-all}"
        }
      },
      "fulfilment-route": {
        "ClusterId": "fulfilment-cluster",
        "RateLimiterPolicy": "standard",
        "Match": {
          "Path": "/api/v1/fulfilment/{**catch-all}"
        }
      },
      "catalog-route": {
        "ClusterId": "catalog-cluster",
        "RateLimiterPolicy": "standard",
        "Match": {
          "Path": "/api/v1/catalog/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-1": { "Address": "http://localhost:5010" }
        }
      },
      "orders-cluster": {
        "Destinations": {
          "orders-1": { "Address": "http://localhost:5030" }
        }
      },
      "payments-cluster": {
        "Destinations": {
          "payments-1": { "Address": "http://localhost:5040" }
        }
      },
      "fulfilment-cluster": {
        "Destinations": {
          "fulfilment-1": { "Address": "http://localhost:5050" }
        }
      },
      "catalog-cluster": {
        "Destinations": {
          "catalog-1": { "Address": "http://localhost:5020" }
        }
      }
    }
  }
}
